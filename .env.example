# Kie.ai API
VITE_KIE_API_KEY=your_kie_api_key_here

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Dupliquer sans préfixe VITE_ sur Vercel pour les fonctions serverless (api/stripe-verify, claim…) si besoin :
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Clé service (API routes : webhook Stripe, admin…) — ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (côté client)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe (côté serveur - pour webhooks)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
# Endpoint webhook Vercel : https://<domaine>/api/stripe-webhook — événement checkout.session.completed
# Après paiement (Payment Link) : URL de succès = https://<domaine>/paiementreussi?session_id={CHECKOUT_SESSION_ID}
# Essai mensuel (1 mytho) : ajoute une période d’essai sur le Payment Link / prix mensuel dans Stripe Dashboard.
# Puis exécute sur Supabase le bloc ALTER subscription_status (voir supabase-schema.sql) si la colonne ne permet pas encore « trialing ».

# PostHog (analytics) — laisse vide en local pour désactiver, remplis sur Vercel
# Récupère la clé sur app.posthog.com → Project Settings → Project ID
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
